{"action":"evaluate","args":{"code":"(function(){const c=document.querySelector('canvas');let gl=null;try{gl=c&&(c.getContext('webgl2')? 'webgl2':(c.getContext('webgl')?'webgl':'none'));}catch(e){gl='err';}const txt=document.body.innerText.replace(/\\s+/g,' ').slice(0,400);return JSON.stringify({canvas:!!c,w:c?c.width:0,h:c?c.height:0,ctx:gl,buttons:[...document.querySelectorAll('button')].map(x=>x.textContent.trim()),txt:txt});})()"},"session":"mc-web-check"}